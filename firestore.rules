rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return myRole() == "admin";
    }

    // User profile + role docs: Users/{uid}
    match /Users/{uid} {
      // User can read own doc, admin can read all, or any signed-in user (needed for chat member names)
      allow read: if isOwner(uid) || isAdmin() || signedIn();

      // User can create only own doc and only as normal user
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(["email", "role"])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == "user";

      // Admin can change roles; users cannot change their own role/email
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.email == resource.data.email);

      allow delete: if isAdmin();
    }

    // Projects: readable by members and admins
    match /projects/{projectId} {
      allow read: if signedIn()
        && (isAdmin() || request.auth.uid in resource.data.memberUid);

      function isMember() {
        return request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberUid;
      }

      // MilestoneGroup documents (title, subtitle, icon, order)
      match /milestoneGroups/{group} {
        allow read: if signedIn() && (isAdmin() || isMember());
      }

      // Milestone task documents inside each group
      match /milestoneGroups/{group}/milestones/{milestone} {
        allow read: if signedIn() && (isAdmin() || isMember());
        allow update: if isAdmin();
      }

      // Chat conversations between project members
      match /chats/{chatId} {
        allow read: if signedIn()
                    && request.auth.uid in resource.data.participants;

        allow create: if signedIn()
                      && request.auth.uid in request.resource.data.participants
                      && request.resource.data.participants.size() == 2;

        allow update: if signedIn()
                      && request.auth.uid in resource.data.participants
                      && request.resource.data.participants == resource.data.participants;

        match /messages/{messageId} {
          allow read: if signedIn()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/projects/$(projectId)/chats/$(chatId)).data.participants;

          allow create: if signedIn()
                        && request.auth.uid in
                           get(/databases/$(database)/documents/projects/$(projectId)/chats/$(chatId)).data.participants
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0;

          allow update, delete: if false;
        }
      }
    }

    // Default deny for everything else until explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}