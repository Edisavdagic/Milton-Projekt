rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function myRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return myRole() == "admin";
    }

    // User profile + role docs: Users/{uid}
    match /Users/{uid} {
      // User can read own doc, admin can read all
      allow read: if isOwner(uid) || isAdmin();

      // User can create only own doc and only as normal user
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(["email", "role"])
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == "user";

      // Admin can change roles; users cannot change their own role/email
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.email == resource.data.email);

      allow delete: if isAdmin();
    }

    // Default deny for everything else until explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}